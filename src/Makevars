CXX_STD = CXX17

UNAME := $(shell uname -s)
ARCH := $(shell uname -m)

ifeq ($(UNAME), Darwin)
    LIBOMP_PATH = $(shell brew --prefix libomp 2>/dev/null || echo /opt/homebrew/opt/libomp)

    ifeq ($(ARCH), arm64)
        PKG_CPPFLAGS = -Wno-ignored-attributes -I$(LIBOMP_PATH)/include
    else
        PKG_CPPFLAGS = -Wno-ignored-attributes -mavx2 -mfma -I$(LIBOMP_PATH)/include
    endif

    PKG_CXXFLAGS = -Xclang -fopenmp
    PKG_LIBS = $(LIBOMP_PATH)/lib/libomp.dylib
else
    PKG_CPPFLAGS = -Wno-ignored-attributes -mavx2 -mfma
    PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS)
    PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS)
endif
